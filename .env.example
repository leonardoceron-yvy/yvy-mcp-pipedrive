# Pipedrive API credentials
# Obter em: Settings → Personal preferences → API
PIPEDRIVE_API_TOKEN=seu_token_aqui

# Domínio da conta (ex: yvy, sem .pipedrive.com)
PIPEDRIVE_DOMAIN=yvy

# Transporte MCP:
#   stdio = Claude Code CLI local
#   http  = Cowork / claude.ai web / qualquer agente remoto
MCP_TRANSPORT=stdio

# Bearer token obrigatório quando MCP_TRANSPORT=http.
# Gerar com: python -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_AUTH_TOKEN=

# Porta para o modo http (Railway sobrescreve com PORT automaticamente)
PORT=8000
